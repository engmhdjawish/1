# PostgreSQL (local development)
PORTAL_DB_HOST=127.0.0.1
PORTAL_DB_PORT=5432
PORTAL_DB_NAME=portal_db
PORTAL_DB_USER=portal
PORTAL_DB_PASSWORD=portal

# Amine API (local ExistingDb.Api)
AMINE_API_BASE_URL=http://127.0.0.1:5000
AMINE_API_USERNAME=portal-service
AMINE_API_PASSWORD=change-me

# Application
PORTAL_APP_URL=http://127.0.0.1:8080
PORTAL_SESSION_NAME=portal_session
PORTAL_STORAGE_PATH=

# Optional: TrueType font for material image detail banners (must be readable by PHP/IIS)
# Example Windows: C:\Windows\Fonts\tahoma.ttf
# Or copy tahoma.ttf to portal/storage/fonts/tahoma.ttf
PORTAL_DETAILS_FONT_PATH=

# Optional: path to repo docs for schema setup
PORTAL_REPO_DOCS_PATH=../docs
