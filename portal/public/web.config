<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <system.webServer>
    <!-- Let PHP return JSON error bodies instead of replacing them with IIS HTML pages. -->
    <httpErrors existingResponse="PassThrough" errorMode="DetailedLocalOnly" />
    <security>
      <requestFiltering>
        <!-- 50 MB — material image uploads are capped at 10 MB in PHP. -->
        <requestLimits maxAllowedContentLength="52428800" />
      </requestFiltering>
    </security>
  </system.webServer>
</configuration>
