# ملف إعدادات النشر — انسخه إلى deploy.env وعدّل القيم
# يُنشئه معالج النشر تلقائياً عند الحفظ

DEPLOY_ENV=production

# --- API (ExistingDb.Api) ---
# Windows: D:\AmeenApi\existingdb-api   |   Linux: /var/www/existingdb-api
API_PUBLISH_DIR=D:\AmeenApi\existingdb-api
API_URL=http://127.0.0.1:5000
API_PORT=5000
API_BIND_HOST=0.0.0.0
MAIN_DB_CONNECTION=Server=SQLHOST;Database=YOUR_DB;User Id=sa;Password=SECRET;TrustServerCertificate=True;
API_MANAGEMENT_DB_CONNECTION=Server=SQLHOST;Database=ApiManagementDb;User Id=sa;Password=SECRET;TrustServerCertificate=True;
JWT_SIGNING_KEY=REPLACE_WITH_32_BYTE_OR_LONGER_SECRET
SEED_ADMIN_ENABLED=false
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_EMAIL=admin@example.local
SEED_ADMIN_PASSWORD=
IMAGES_DIRECTORY=C:\images

# --- Portal (PHP) ---
PORTAL_SOURCE_DIR=
# Path ON THE SERVER (used in .env and packaging):
PORTAL_PUBLISH_DIR=D:\JawishPortal
# Local packaging output uses deploy\output\server-package (see package-for-server.ps1)
PORTAL_REPO_DOCS_PATH=
PORTAL_APP_URL=https://portal.example.com
PORTAL_FORCE_HTTPS=true
PORTAL_DB_HOST=127.0.0.1
PORTAL_DB_PORT=5432
PORTAL_DB_NAME=portal_db
PORTAL_DB_USER=portal
PORTAL_DB_PASSWORD=change-me
AMINE_API_USERNAME=portal-service
AMINE_API_PASSWORD=change-me
PORTAL_SESSION_NAME=portal_session
PORTAL_STORAGE_PATH=
PORTAL_ADMIN_USER=admin
PORTAL_ADMIN_PASSWORD=
PORTAL_ADMIN_DISPLAY_NAME=مدير النظام

# --- خادم ويب (اختياري — للقوالب) ---
WEB_SERVER=nginx
WEB_DOMAIN=portal.example.com
WEB_SSL=false
